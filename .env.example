ARTEMIDE_API_TOKEN=replace-with-openssl-rand-hex-32
TUNNEL_TOKEN=paste-from-cloudflare
ARTEMIDE_DB_PATH=/data/artemide.db
ARTEMIDE_BIND_HOST=0.0.0.0
ARTEMIDE_BIND_PORT=8000
ARTEMIDE_LOG_LEVEL=INFO
ARTEMIDE_ENABLE_DOCS=false
ARTEMIDE_UI_BUILD_PATH=/app/web/dist
ARTEMIDE_COOKIE_SECRET=replace-with-openssl-rand-hex-32
ARTEMIDE_COOKIE_DOMAIN=artemide.francescofederico.net
ARTEMIDE_COOKIE_SECURE=true

# v1.2 — engagement & programme extension
ARTEMIDE_N8N_TOKEN=replace-with-openssl-rand-hex-32   # bot-role token, issued via Settings → Automation; first-boot fallback only
ARTEMIDE_PROGRAMME_TARGET_DATE=2027-04-05             # the date the programme works back from
ARTEMIDE_OUTBOX_ENABLED=true
ARTEMIDE_OUTBOX_ATTEMPT_CAP=10
ARTEMIDE_OUTBOX_SWEEP_INTERVAL=300                    # seconds between in-process outbox sweeps
