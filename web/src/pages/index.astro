---
import AppShell from '../components/layout/AppShell.astro';
import PipelineOverview from '../components/dashboard/PipelineOverview';
import NextActions from '../components/dashboard/NextActions';
import AuditHighlights from '../components/dashboard/AuditHighlights';
import OutreachMetricsTiles from '../components/dashboard/OutreachMetricsTiles';
import BoardSearchTile from '../components/dashboard/BoardSearchTile';
import ProgrammeBanner from '../components/v12/ProgrammeBanner';
---
<AppShell title="Dashboard · Artemide" current="dashboard">
  <header class="page-head">
    <h1>Dashboard</h1>
    <p class="page-subhead">Programme status, pipeline, upcoming touches, audit highlights.</p>
  </header>

  <ProgrammeBanner client:load />

  <OutreachMetricsTiles client:load />

  <BoardSearchTile client:load />

  <div class="dashboard-grid">
    <div class="dashboard-grid__nextactions">
      <NextActions client:load />
    </div>
    <div class="dashboard-grid__pipeline">
      <PipelineOverview client:load />
    </div>
    <div class="dashboard-grid__audit">
      <AuditHighlights client:load />
    </div>
  </div>
</AppShell>

<style>
  .page-head {
    margin-bottom: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .page-subhead { color: var(--charcoal-muted); }

  .dashboard-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    grid-template-areas:
      "nextactions"
      "pipeline"
      "audit";
    gap: var(--space-4);
  }
  .dashboard-grid__nextactions { grid-area: nextactions; }
  .dashboard-grid__pipeline { grid-area: pipeline; }
  .dashboard-grid__audit { grid-area: audit; }
</style>
