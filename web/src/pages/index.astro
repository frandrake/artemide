---
import AppShell from '../components/layout/AppShell.astro';
import TodayCommandCenter from '../components/dashboard/TodayCommandCenter';
---
<AppShell title="Today · Artemide" current="today" domain="shared">
  <header class="today-page__head">
    <p class="today-page__eyebrow">OWNER COMMAND CENTRE</p>
    <h1>Today</h1>
    <p>One ranked view across two confidential workstreams. Every record remains in its source domain.</p>
  </header>
  <TodayCommandCenter client:load />
</AppShell>

<style>
  .today-page__head { margin-bottom: var(--space-4); max-width: 760px; }
  .today-page__head h1 { font-family: var(--font-serif); color: var(--charcoal); margin: 0 0 var(--space-1); }
  .today-page__head p { color: var(--charcoal-muted); }
  .today-page__eyebrow { color: var(--vermillion) !important; font-size: var(--text-xs); font-weight: var(--font-weight-bold); letter-spacing: .12em; margin-bottom: var(--space-1); }
</style>
