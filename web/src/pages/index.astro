---
import AppShell from '../components/layout/AppShell.astro';
import PipelineOverview from '../components/dashboard/PipelineOverview';
import UpcomingTouches from '../components/dashboard/UpcomingTouches';
import AuditHighlights from '../components/dashboard/AuditHighlights';
---
<AppShell title="Dashboard · Artemide" current="dashboard">
  <header class="page-head">
    <h1>Dashboard</h1>
    <p class="page-subhead">Pipeline state, upcoming touches, audit highlights.</p>
  </header>

  <div class="dashboard-grid">
    <div class="dashboard-grid__pipeline">
      <PipelineOverview client:load />
    </div>
    <div class="dashboard-grid__upcoming">
      <UpcomingTouches client:load />
    </div>
    <div class="dashboard-grid__audit">
      <AuditHighlights client:load />
    </div>
  </div>
</AppShell>

<style>
  .page-head {
    margin-bottom: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .page-subhead { color: var(--charcoal-muted); }

  .dashboard-grid {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
    grid-template-areas:
      "pipeline pipeline"
      "upcoming audit";
    gap: var(--space-4);
  }
  .dashboard-grid__pipeline { grid-area: pipeline; }
  .dashboard-grid__upcoming { grid-area: upcoming; }
  .dashboard-grid__audit { grid-area: audit; }

  @media (max-width: 900px) {
    .dashboard-grid {
      grid-template-columns: 1fr;
      grid-template-areas:
        "pipeline"
        "upcoming"
        "audit";
    }
  }
</style>
