---
import AppShell from '../../components/layout/AppShell.astro';
import BoardContactsList from '../../components/board/BoardContactsList';
---
<AppShell title="Board · Contacts" current="board-contacts" domain="board">
  <header class="bd-head">
    <h1>Board contacts</h1>
    <p class="bd-subhead">Chairs, partners and connectors. Stale contacts are flagged to re-verify.</p>
  </header>
  <BoardContactsList client:load />
</AppShell>

<style>
  .bd-head { margin-bottom: var(--space-4); display: flex; flex-direction: column; gap: var(--space-1); }
  .bd-subhead { color: var(--charcoal-muted); }
  .bd-head h1 { font-family: var(--font-serif); }
</style>
