---
import AppShell from '../../components/layout/AppShell.astro';
import IntakeWorkbench from '../../components/intake/IntakeWorkbench';
---
<AppShell title="Board AI intake · Artemide" current="board-intake" domain="board">
  <header class="page-head">
    <p>BOARD / NED — CONFIDENTIAL</p>
    <h1>AI intake review</h1>
    <span>Board proposals are staged and audited in their own domain. Nothing is copied into Executive search.</span>
  </header>
  <IntakeWorkbench domain="board" client:load />
</AppShell>
<style>
  .page-head{margin-bottom:var(--space-4);max-width:780px}.page-head p{font-size:var(--text-xs);font-weight:700;letter-spacing:.12em;color:var(--vermillion)}.page-head h1{font-family:var(--font-serif);margin:0 0 var(--space-1)}.page-head span{color:var(--charcoal-muted)}
</style>
