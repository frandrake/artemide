---
import AppShell from '../../components/layout/AppShell.astro';
import OutreachDue from '../../components/board/OutreachDue';
---
<AppShell title="Board · Due" current="board-due" domain="board">
  <header class="bd-head">
    <h1>Outreach due</h1>
    <p class="bd-subhead">Board interactions, open tasks and stale contacts due in the next two weeks.</p>
  </header>
  <OutreachDue client:load />
</AppShell>

<style>
  .bd-head { margin-bottom: var(--space-4); display: flex; flex-direction: column; gap: var(--space-1); }
  .bd-subhead { color: var(--charcoal-muted); }
  .bd-head h1 { font-family: var(--font-serif); }
</style>
