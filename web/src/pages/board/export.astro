---
import AppShell from '../../components/layout/AppShell.astro';
import BoardExport from '../../components/board/BoardExport';
---
<AppShell title="Board · Export" current="board-export" domain="board">
  <header class="bd-head">
    <h1>Export board domain</h1>
    <p class="bd-subhead">Per-domain export — kept apart from the executive search corpus.</p>
  </header>
  <BoardExport client:load />
</AppShell>

<style>
  .bd-head { margin-bottom: var(--space-4); display: flex; flex-direction: column; gap: var(--space-1); }
  .bd-subhead { color: var(--charcoal-muted); }
  .bd-head h1 { font-family: var(--font-serif); }
</style>
