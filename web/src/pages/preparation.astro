---
import AppShell from '../components/layout/AppShell.astro';
import PreparationWorkbench from '../components/preparation/PreparationWorkbench';
---
<AppShell title="Executive preparation packs · Artemide" current="preparation" domain="exec">
  <header class="page-head"><p>EXECUTIVE SEARCH</p><h1>Preparation packs</h1><span>Versioned contact, organisation and opportunity briefs with immutable source provenance.</span></header>
  <PreparationWorkbench domain="executive" client:load />
</AppShell>
<style>.page-head{margin-bottom:var(--space-4);max-width:780px}.page-head p{font-size:var(--text-xs);font-weight:700;letter-spacing:.12em;color:var(--slate-blue)}.page-head h1{font-family:var(--font-serif);margin:0 0 var(--space-1)}.page-head span{color:var(--charcoal-muted)}</style>
