---
import AppShell from '../components/layout/AppShell.astro';
import PipelinePage from '../components/pipeline/PipelinePage';
---
<AppShell title="Search-firm outreach · Artemide" current="pipeline">
  <header class="page-head">
    <h1>Search-firm outreach</h1>
    <p class="page-subhead">Where each partner is in the outreach cycle. Drag to advance.</p>
  </header>
  <PipelinePage client:load />
</AppShell>

<style>
  .page-head { margin-bottom: var(--space-4); display: flex; flex-direction: column; gap: var(--space-1); }
  .page-subhead { color: var(--charcoal-muted); }
</style>
