---
import AppShell from '../components/layout/AppShell.astro';
import EngagementCalendarPage from '../components/engagement/EngagementCalendarPage';
---
<AppShell title="Engagement · Artemide" current="engagement">
  <header class="page-head">
    <h1>Engagement calendar</h1>
    <p class="page-subhead">12-month outreach plan across six tracks.</p>
  </header>
  <EngagementCalendarPage client:load />
</AppShell>

<style>
  .page-head {
    margin-bottom: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .page-subhead { color: var(--charcoal-muted); }
</style>
