---
import AppShell from '../components/layout/AppShell.astro';
import DraftsList from '../components/outreach/DraftsList';
---
<AppShell title="Drafts · Artemide" current="drafts">
  <header class="page-head">
    <h1>Drafts</h1>
    <p class="page-subhead">Outreach in flight. Open one to edit, send, or archive.</p>
  </header>
  <DraftsList client:load />
</AppShell>

<style>
  .page-head { margin-bottom: var(--space-4); display: flex; flex-direction: column; gap: var(--space-1); }
  .page-subhead { color: var(--charcoal-muted); }
</style>
