---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from './Header.astro';

interface Props {
  title?: string;
  domain?: 'exec' | 'board';
  current?:
    | 'dashboard' | 'firms' | 'plan' | 'audit' | 'notes' | 'search' | 'settings'
    | 'engagement' | 'drafts' | 'templates' | 'pipeline'
    | 'engagements' | 'orgs' | 'messages' | 'programme' | 'compensation'
    | 'board-home' | 'board-firms' | 'board-contacts' | 'board-opportunities'
    | 'board-pipeline' | 'board-conflicts' | 'board-evaluations' | 'board-due'
    | 'board-competitors' | 'board-tasks' | 'board-export';
}
const { title, current, domain = 'exec' } = Astro.props;
---
<BaseLayout title={title}>
  <Header slot="header" current={current} domain={domain} />
  <div class="container">
    <slot />
  </div>
</BaseLayout>

<style>
  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--space-4) var(--space-3) var(--space-6);
  }
  @media (max-width: 720px) {
    .container { padding: var(--space-3) var(--space-2) var(--space-5); }
  }
</style>
