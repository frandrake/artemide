---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from './Header.astro';

interface Props {
  title?: string;
  current?:
    | 'dashboard' | 'firms' | 'plan' | 'audit' | 'notes' | 'search' | 'settings'
    | 'engagement' | 'drafts' | 'templates' | 'pipeline';
}
const { title, current } = Astro.props;
---
<BaseLayout title={title}>
  <Header slot="header" current={current} />
  <div class="container">
    <slot />
  </div>
</BaseLayout>

<style>
  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--space-4) var(--space-3) var(--space-6);
  }
  @media (max-width: 720px) {
    .container { padding: var(--space-3) var(--space-2) var(--space-5); }
  }
</style>
