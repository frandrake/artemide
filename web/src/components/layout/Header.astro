---
interface Props { current?: 'dashboard' | 'firms' | 'plan' | 'audit' | 'notes'; }
const { current } = Astro.props;

const links = [
  { id: 'dashboard', href: '/', label: 'Dashboard' },
  { id: 'firms', href: '/firms', label: 'Firms' },
  { id: 'plan', href: '/plan', label: 'Plan' },
  { id: 'audit', href: '/audit', label: 'Audit' },
  { id: 'notes', href: '/notes', label: 'Notes' },
] as const;
---
<header class="header">
  <div class="header-inner">
    <a class="brand" href="/" aria-label="Artemide home">
      <span class="brand-mark">FF</span>
      <span class="brand-rule" aria-hidden="true"></span>
    </a>

    <nav class="nav" aria-label="Primary">
      {links.map(({ id, href, label }) => (
        <a
          href={href}
          class:list={['nav-link', current === id && 'is-current']}
          aria-current={current === id ? 'page' : undefined}
        >{label}</a>
      ))}
    </nav>

    <div class="header-actions">
      <label class="search">
        <span class="visually-hidden">Search</span>
        <input type="search" placeholder="Search" aria-label="Search" />
      </label>
      <form method="post" action="/logout" class="logout-form">
        <button type="submit" class="logout">Sign out</button>
      </form>
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    height: var(--header-height);
    background: var(--cool-white);
    border-bottom: var(--border-width) solid var(--border-subtle);
  }
  .header-inner {
    height: 100%;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-3);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-3);
  }
  .brand {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
    text-decoration: none;
  }
  .brand-mark {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 24px;
    line-height: 1;
    color: var(--slate-blue);
    letter-spacing: 0.02em;
  }
  .brand-rule {
    display: block;
    width: 24px;
    height: var(--accent-line-width);
    background: var(--vermillion);
  }

  .nav {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }
  .nav-link {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--slate-blue);
    padding: var(--space-1) 0;
    border-bottom: 2px solid transparent;
    transition: border-color var(--duration-quick) var(--easing);
  }
  .nav-link:hover { border-bottom-color: var(--slate-blue-40); }
  .nav-link.is-current { border-bottom-color: var(--slate-blue); }

  .header-actions {
    display: flex;
    gap: var(--space-2);
    align-items: center;
  }
  .search input {
    width: 180px;
    padding: 6px 12px;
    font-size: var(--text-sm);
    border: 1px solid var(--light-gray);
    border-radius: var(--radius-sm);
    background: var(--pure-white);
    transition: width var(--duration-normal) var(--easing), border-color var(--duration-quick) var(--easing);
  }
  .search input:focus {
    width: 240px;
    outline: none;
    border-color: var(--slate-blue);
  }
  .logout-form { margin: 0; }
  .logout {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--slate-blue);
    background: transparent;
    border: none;
    padding: var(--space-1) var(--space-2);
    min-height: 44px;
  }
  .logout:hover { color: var(--vermillion); }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 720px) {
    .header-inner {
      grid-template-columns: auto auto;
      grid-template-rows: auto auto;
      row-gap: var(--space-1);
    }
    .nav {
      grid-column: 1 / -1;
      order: 3;
      gap: var(--space-2);
      justify-content: flex-start;
      overflow-x: auto;
    }
    .search input { width: 140px; }
    .search input:focus { width: 180px; }
  }
</style>
