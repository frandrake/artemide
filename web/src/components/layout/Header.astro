---
type ExecCurrent =
  | 'dashboard' | 'firms' | 'plan' | 'audit' | 'notes' | 'search' | 'settings'
  | 'engagement' | 'drafts' | 'templates' | 'pipeline'
  | 'engagements' | 'orgs' | 'messages' | 'programme' | 'compensation';
type BoardCurrent =
  | 'board-home' | 'board-firms' | 'board-contacts' | 'board-opportunities'
  | 'board-pipeline' | 'board-conflicts' | 'board-evaluations' | 'board-due'
  | 'board-competitors' | 'board-tasks' | 'board-export';

interface Props {
  current?: ExecCurrent | BoardCurrent;
  domain?: 'exec' | 'board';
}
const { current, domain = 'exec' } = Astro.props;
const isBoard = domain === 'board';

const execPrimary = [
  { id: 'dashboard', href: '/', label: 'Dashboard' },
  { id: 'firms', href: '/firms', label: 'Firms' },
  { id: 'engagements', href: '/engagements', label: 'Engagements' },
  { id: 'messages', href: '/messages', label: 'Messages' },
  { id: 'programme', href: '/programme', label: 'Programme' },
  { id: 'plan', href: '/plan', label: 'Plan' },
  { id: 'audit', href: '/audit', label: 'Audit' },
];
const execMore = [
  { id: 'orgs', href: '/orgs', label: 'Organisations' },
  { id: 'pipeline', href: '/pipeline', label: 'Outreach pipeline' },
  { id: 'engagement', href: '/engagement', label: 'Engagement calendar' },
  { id: 'drafts', href: '/drafts', label: 'Drafts' },
  { id: 'templates', href: '/templates', label: 'Templates' },
  { id: 'compensation', href: '/compensation', label: 'Compensation' },
  { id: 'search', href: '/search', label: 'Search' },
  { id: 'notes', href: '/notes', label: 'Notes' },
  { id: 'audit-log', href: '/audit/log', label: 'Audit log' },
  { id: 'settings', href: '/settings', label: 'Settings' },
];

const boardPrimary = [
  { id: 'board-home', href: '/board', label: 'Platform log' },
  { id: 'board-opportunities', href: '/board/opportunities', label: 'Opportunities' },
  { id: 'board-pipeline', href: '/board/pipeline', label: 'Pipeline' },
  { id: 'board-conflicts', href: '/board/conflict-queue', label: 'Conflicts' },
  { id: 'board-evaluations', href: '/board/evaluations', label: 'Evaluations' },
  { id: 'board-due', href: '/board/outreach-due', label: 'Due' },
];
const boardMore = [
  { id: 'board-firms', href: '/board/firms', label: 'Firms' },
  { id: 'board-contacts', href: '/board/contacts', label: 'Contacts' },
  { id: 'board-tasks', href: '/board/tasks', label: 'Tasks' },
  { id: 'board-competitors', href: '/board/competitors', label: 'Competitors (S&P)' },
  { id: 'board-export', href: '/board/export', label: 'Export' },
];

const primary = isBoard ? boardPrimary : execPrimary;
const more = isBoard ? boardMore : execMore;
---
<header class:list={['header', isBoard && 'header--board']}>
  <div class="header-inner">
    <a class="brand" href={isBoard ? '/board' : '/'} aria-label="Artemide home">
      <span class="brand-row">
        <span class="brand-mark"><span class="brand-mark-accent">A</span>rtemid<span class="brand-mark-accent">e</span></span>
        {isBoard && <span class="board-pill">BOARD</span>}
      </span>
      <span class="brand-rule" aria-hidden="true"></span>
    </a>

    <nav class="nav" aria-label="Primary">
      {primary.map(({ id, href, label }) => (
        <a
          href={href}
          class:list={['nav-link', current === id && 'is-current']}
          aria-current={current === id ? 'page' : undefined}
        >{label}</a>
      ))}

      <details class="nav-more">
        <summary>More ▾</summary>
        <ul>
          {more.map(({ id, href, label }) => (
            <li>
              <a href={href} class:list={['nav-link', current === id && 'is-current']}>{label}</a>
            </li>
          ))}
        </ul>
      </details>
    </nav>

    <div class="header-actions">
      <div class="domain-switch" role="group" aria-label="Search domain">
        <a class:list={['domain-switch__opt', !isBoard && 'is-active']} href="/" aria-current={!isBoard ? 'true' : undefined}>Exec</a>
        <a class:list={['domain-switch__opt', isBoard && 'is-active']} href="/board" aria-current={isBoard ? 'true' : undefined}>Board</a>
      </div>
      {!isBoard && (
        <form class="search" action="/search" method="get" role="search">
          <label class="visually-hidden" for="header-search">Search</label>
          <input id="header-search" type="search" name="q" placeholder="Search" aria-label="Search" />
        </form>
      )}
      <form method="post" action="/logout" class="logout-form">
        <button type="submit" class="logout">Sign out</button>
      </form>
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    height: var(--header-height);
    background: var(--cool-white);
    border-bottom: var(--border-width) solid var(--border-subtle);
  }
  /* Board mode: a vermillion spine reinforces the confidential domain. */
  .header--board { border-bottom: var(--accent-line-width) solid var(--vermillion); }
  .header-inner {
    height: 100%;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-3);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-3);
  }
  .brand {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
    text-decoration: none;
  }
  .brand-row { display: inline-flex; align-items: center; gap: var(--space-1); }
  .brand-mark {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 24px;
    line-height: 1;
    color: var(--slate-blue);
    letter-spacing: 0.02em;
  }
  .brand-mark-accent { color: var(--vermillion); }
  .board-pill {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.08em;
    color: var(--cool-white);
    background: var(--vermillion);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
  }
  .brand-rule {
    display: block;
    width: 24px;
    height: var(--accent-line-width);
    background: var(--vermillion);
  }

  .nav {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
    align-items: center;
  }
  .nav-link {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--slate-blue);
    padding: var(--space-1) 0;
    border-bottom: 2px solid transparent;
    transition: border-color var(--duration-quick) var(--easing);
  }
  .nav-link:hover { border-bottom-color: var(--slate-blue-40); }
  .nav-link.is-current { border-bottom-color: var(--slate-blue); }
  .header--board .nav-link.is-current { border-bottom-color: var(--vermillion); }

  .nav-more { position: relative; }
  .nav-more > summary {
    cursor: pointer;
    list-style: none;
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--slate-blue);
    padding: var(--space-1) 0;
    min-height: 32px;
  }
  .nav-more > summary::-webkit-details-marker { display: none; }
  .nav-more > ul {
    position: absolute;
    top: 100%;
    right: 0;
    min-width: 180px;
    list-style: none;
    margin: var(--space-1) 0 0;
    padding: var(--space-1);
    background: var(--pure-white);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    z-index: var(--z-overlay);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .nav-more a {
    display: block;
    padding: 8px 12px;
    border-radius: var(--radius-sm);
    border-bottom: none;
  }
  .nav-more a:hover { background: var(--light-gray); }

  .header-actions {
    display: flex;
    gap: var(--space-2);
    align-items: center;
  }
  .domain-switch {
    display: inline-flex;
    border: 1px solid var(--light-gray);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }
  .domain-switch__opt {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--slate-blue);
    padding: 4px 10px;
    text-decoration: none;
    background: var(--pure-white);
  }
  .domain-switch__opt + .domain-switch__opt { border-left: 1px solid var(--light-gray); }
  .domain-switch__opt.is-active { background: var(--slate-blue); color: var(--cool-white); }
  .header--board .domain-switch__opt.is-active { background: var(--vermillion); }

  .search { margin: 0; }
  .search input {
    width: 180px;
    padding: 6px 12px;
    font-size: var(--text-sm);
    border: 1px solid var(--light-gray);
    border-radius: var(--radius-sm);
    background: var(--pure-white);
    transition: width var(--duration-normal) var(--easing), border-color var(--duration-quick) var(--easing);
  }
  .search input:focus {
    width: 240px;
    outline: none;
    border-color: var(--slate-blue);
  }
  .logout-form { margin: 0; }
  .logout {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--slate-blue);
    background: transparent;
    border: none;
    padding: var(--space-1) var(--space-2);
    min-height: 44px;
  }
  .logout:hover { color: var(--vermillion); }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 720px) {
    .header-inner {
      grid-template-columns: auto auto;
      grid-template-rows: auto auto;
      row-gap: var(--space-1);
    }
    .nav {
      grid-column: 1 / -1;
      order: 3;
      gap: var(--space-2);
      justify-content: flex-start;
      overflow-x: auto;
    }
    .search input { width: 140px; }
    .search input:focus { width: 180px; }
  }
</style>
