{
  "id": "artemide-inbound",
  "versionId": "artemide-inbound-v1",
  "name": "Artemide \u00b7 Inbound triage",
  "nodes": [
    {
      "parameters": {
        "event": "messageReceived"
      },
      "id": "bot-mailbox-watch",
      "name": "Bot mailbox watch",
      "type": "n8n-nodes-base.microsoftOutlookTrigger",
